{
  "name": "reffy-cli",
  "version": "1.3.0",
  "description": "Planning system for AI assisted development.",
  "keywords": [
    "reffy",
    "reffyspec",
    "specs",
    "cli",
    "ai",
    "development",
    "sdd"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RoskiDeluge/reffy.git"
  },
  "homepage": "https://github.com/RoskiDeluge/reffy",
  "bugs": {
    "url": "https://github.com/RoskiDeluge/reffy/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "reffy": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "dev": "tsx watch src/cli.ts",
    "check": "tsc --noEmit",
    "remote:backend:demo": "node scripts/reffy-remote-backend-demo.mjs",
    "test": "npm run build && vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "dependencies": {
    "beautiful-mermaid": "^0.1.3",
    "mime-types": "^2.1.35",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^24.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
